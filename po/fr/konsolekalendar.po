msgid "Laurent Montel"
msgstr "Laurent Montel"

#: main.cpp:63
#, kde-format
msgid "Bug fixing"
msgstr "Correction de bogues"

#: main.cpp:64
#, kde-format
msgctxt "@info:credit"
msgid "Allen Winter"
msgstr "Allen Winter"

#: main.cpp:64
#, kde-format
msgid "Maintainer"
msgstr "Mainteneur"

