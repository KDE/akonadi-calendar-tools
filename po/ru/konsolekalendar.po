#, kde-format
msgid "Sorry, To-dos are not working yet."
msgstr "Извините, работа с задачами пока не реализована."

#: main.cpp:183
#, kde-format
msgid "Sorry, Journals are not working yet."
msgstr "Извините, работа с дневниками пока не реализована."

