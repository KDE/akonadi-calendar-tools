#, kde-format
msgid "Incidence Unique-string identifier"
msgstr "事件唯一的字符串标识符"

#: main.cpp:90
#, kde-format
msgid "Start from this day [YYYY-MM-DD]"
msgstr "从该天起[YYYY-MM-DD]"

