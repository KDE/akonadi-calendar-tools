#, kde-format
msgid "Export file type (Default: text)"
msgstr "导出文件类型(默认：文本)"

#: main.cpp:112
#, kde-format
msgid "Export to file (Default: stdout)"
msgstr "导出到文件(默认：stdout)"

#: main.cpp:113
#, kde-format
msgid "Print list of export types supported and exit"
msgstr "打印所支持的导出类型列表并退出"

